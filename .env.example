# Keep real values in an uncommitted .env.local file or in the deployment environment.
# Do not commit secrets, access tokens, or OAuth credentials.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Google OAuth for account-backed carts. Register the approved callback URLs in Google:
# https://printaway.vercel.app/api/auth/callback/google
# https://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=

# Square server configuration. Inventory is read from Square using the variation IDs below.
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=
SQUARE_MONITOR_RISER_VARIATION_ID=
SQUARE_DESK_TRAY_VARIATION_ID=
SQUARE_COAT_HANGER_VARIATION_ID=
SQUARE_KEYCAP_FIDGET_VARIATION_ID=
